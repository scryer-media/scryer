# ─── Network ──────────────────────────────────────────────────────────
# Address and port to bind the HTTP server.
# SCRYER_BIND=127.0.0.1:8080

# Comma-separated list of allowed CORS origins (default includes localhost:3000 variants).
# Set to "*" to allow all origins.
# SCRYER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database ─────────────────────────────────────────────────────────
# SQLite database path. Use a file path for persistence or in-memory for dev.
# SCRYER_DB_PATH=sqlite:///data/scryer.db

# Migration mode: "apply" (default), "validate-only"
# SCRYER_DB_MIGRATION_MODE=apply

# ─── Authentication ───────────────────────────────────────────────────
# Default admin credentials: admin / admin (change in Settings > Users).

# JWT issuer claim.
# SCRYER_JWT_ISSUER=scryer

# JWT access token TTL in seconds (default: 86400 = 24 hours).
# SCRYER_JWT_ACCESS_TTL_SECONDS=86400

# EC P-256 private key in PEM format for JWT signing.
# If not set, a key pair is auto-generated and stored in the database.
# SCRYER_JWT_EC_PRIVATE_PEM=

# ─── Encryption ───────────────────────────────────────────────────────
# 32-byte hex-encoded master encryption key for encrypting sensitive data at rest.
# If not set, a key is auto-generated and stored in the database.
# SCRYER_ENCRYPTION_KEY=

# ─── Metadata Gateway ────────────────────────────────────────────────
# GraphQL endpoint for the metadata gateway service.
# SCRYER_METADATA_GATEWAY_GRAPHQL_URL=http://127.0.0.1:8090/graphql

# ─── Download Client (NZBGet) ────────────────────────────────────────
# NZBGet JSON-RPC endpoint URL.
# SCRYER_NZBGET_URL=http://127.0.0.1:6789/jsonrpc

# NZBGet authentication credentials.
# SCRYER_NZBGET_USERNAME=
# SCRYER_NZBGET_PASSWORD=

# NZBGet duplicate handling mode: "score", "all", or "force".
# SCRYER_NZBGET_DUPE_MODE=score

# ─── Indexer (NZBGeek) ───────────────────────────────────────────────
# NZBGeek API key (required to enable indexer searches).
# SCRYER_NZBGEEK_API_KEY=

# NZBGeek display name and base URL.
# SCRYER_NZBGEEK_NAME=NZBGeek
# SCRYER_NZBGEEK_API_BASE_URL=https://api.nzbgeek.info

# Rate limiting for NZBGeek API requests.
# SCRYER_NZBGEEK_RATE_LIMIT_SECONDS=
# SCRYER_NZBGEEK_RATE_LIMIT_BURST=

# Enable or disable the NZBGeek indexer (default: true).
# SCRYER_NZBGEEK_ENABLED=true

# ─── Media Paths ─────────────────────────────────────────────────────
# Root directories for media library storage.
# SCRYER_MOVIES_PATH=/media/movies
# SCRYER_SERIES_PATH=/media/series

# ─── TLS ──────────────────────────────────────────────────────────────
# Paths to PEM-encoded TLS certificate and private key.
# Both must be set to enable TLS; otherwise the server runs plain HTTP.
# SCRYER_TLS_CERT=
# SCRYER_TLS_KEY=

# ─── Background Tasks ────────────────────────────────────────────────
# Enable or disable the background acquisition poller (default: true).
# SCRYER_BACKGROUND_ACQUISITION=true

# ─── Web UI ───────────────────────────────────────────────────────────
# Override the embedded web UI with a local build directory.
# SCRYER_WEB_DIST_DIR=

# URL of the web UI (used for fallback page links).
# SCRYER_WEB_UI_URL=http://127.0.0.1:3000

# ─── Development ──────────────────────────────────────────────────────
# Bypass authentication for all requests (only allowed on loopback addresses).
# SCRYER_DEV_AUTO_LOGIN=false

# Path to a TOML dev seed file for bootstrapping test data.
# SCRYER_DEV_SEED_FILE=

# ─── Logging ──────────────────────────────────────────────────────────
# Standard Rust tracing filter (e.g., "info", "scryer=debug").
# RUST_LOG=info
